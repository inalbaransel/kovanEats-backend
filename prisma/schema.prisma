generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMLAR ---

enum Role {
  CUSTOMER
  RESTAURANT_ADMIN
}

enum OrderType {
  DELIVERY
  DINE_IN
}

enum OrderStatus {
  PENDING      // Bekliyor (Yeni Sipariş)
  PREPARING    // Hazırlanıyor
  READY        // Hazır (Teslimata/Servise hazır)
  COMPLETED    // Tamamlandı / Ödendi
  CANCELLED    // İptal Edildi
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// --- MODELLER ---

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  restaurants Restaurant[] // Eğer RESTAURANT_ADMIN ise yönettiği restoran(lar)
  orders      Order[]      // Eğer CUSTOMER ise verdiği siparişler
}

model Restaurant {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  coverUrl    String?
  address     String?
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])

  // İlişkiler
  categories     Category[]
  tables         Table[]
  orders         Order[]
  modifierGroups ModifierGroup[]
}

model Table {
  id           String   @id @default(uuid())
  tableNumber  String   // Örn: "Masa 22"
  qrCodeUrl    String?  // Üretilen QR kodun görsel linki veya hash'i
  isActive     Boolean  @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  // Bir masanın o anki aktif siparişleri/oturumları olabilir
  orders       Order[]
}

model Category {
  id           String   @id @default(uuid())
  name         String   // Örn: "Ana Yemekler", "İçecekler"
  sortOrder    Int      @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  menuItems    MenuItem[]
}

model MenuItem {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  // Bu ürüne özel seçilebilecek özelleştirme grupları (Örn: "Pizza Boyutu", "Ekstra Malzemeler")
  itemModifiers ItemModifierGroup[]
  orderItems    OrderItem[]
}

// --- ÖZELLEŞTİRMELER (MODIFIERS) ---

// Restoranın genel özelleştirme havuzu (Örn: "İçecek Boyutu", "Porsiyon")
model ModifierGroup {
  id           String   @id @default(uuid())
  name         String   // Örn: "Ekstra Malzemeler"
  isRequired   Boolean  @default(false)
  minSelection Int      @default(0)
  maxSelection Int      @default(1)
  
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  options      ModifierOption[]
  menuItems    ItemModifierGroup[]
}

// Özelleştirme seçenekleri (Örn: "Ketçap (+5 TL)", "Büyük Boy (+20 TL)")
model ModifierOption {
  id              String   @id @default(uuid())
  name            String
  priceAdjustment Decimal  @default(0) @db.Decimal(10, 2) // Ek ücret
  
  groupId         String
  group           ModifierGroup @relation(fields: [groupId], references: [id])

  orderItemModifiers OrderItemModifier[]
}

// MenuItem ile ModifierGroup arasındaki Çoka-Çok ilişki tablosu
model ItemModifierGroup {
  menuItemId      String
  modifierGroupId String
  
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id])
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@id([menuItemId, modifierGroupId])
}

// --- SİPARİŞ (ORDER) YAPISI ---

model Order {
  id            String        @id @default(uuid())
  orderType     OrderType
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  totalAmount   Decimal       @db.Decimal(10, 2)
  notes         String?       // Müşteri notu
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  restaurantId  String
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])

  // CUSTOMER siparişi ise (Masadan misafir girişi ile de verilebilir, nullable)
  customerId    String?
  customer      User?         @relation(fields: [customerId], references: [id])

  // DINE_IN ise hangi masa (DELIVERY ise null)
  tableId       String?
  table         Table?        @relation(fields: [tableId], references: [id])

  items         OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2) // O anki fiyatı sabitlemek için
  totalPrice Decimal  @db.Decimal(10, 2) // Miktar * (Birim Fiyat + Modifier Fiyatları)
  
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  // Seçilen özelleştirmeler
  selectedModifiers OrderItemModifier[]
}

// Sipariş edilen üründe seçilmiş ekstra malzemeler/seçenekler
model OrderItemModifier {
  id               String         @id @default(uuid())
  orderItemId      String
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id])
  
  modifierOptionId String
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id])
  
  priceAtTime      Decimal        @db.Decimal(10, 2) // Seçildiği andaki ekstra fiyat
}
